    dplyr,
    tidyr,
    lubridate,
    patchwork,
    scales,
    RColorBrewer,
    gridExtra,
    reshape2,
    corrplot,
    yaml
Suggests:
    testthat (>= 3.0.0)
Config/roxygen2/version: 8.0.0
